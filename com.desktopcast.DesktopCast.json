{
    "id": "com.desktopcast.DesktopCast",
    "runtime": "org.gnome.Platform",
    "runtime-version": "48",
    "sdk": "org.gnome.Sdk",
    "command": "desktopcast",
    "finish-args": [
        "--device=dri",
        "--share=ipc",
        "--share=network",
        "--socket=pulseaudio",
        "--socket=wayland",
        "--socket=fallback-x11",
        "--system-talk-name=org.freedesktop.Avahi",
        "--system-talk-name=org.freedesktop.NetworkManager",
        "--system-talk-name=org.fedoraproject.FirewallD1",
        "--talk-name=org.kde.StatusNotifierWatcher"
    ],
    "modules": [
        "build-aux/flatpak/files/intltool/intltool.json",
        "build-aux/flatpak/files/avahi/avahi.json",
        "build-aux/flatpak/files/firewalld/firewalld.json",
        "build-aux/flatpak/files/gst-plugins-ugly/gst-plugins-ugly.json",
        "build-aux/flatpak/files/gst-rtsp-server/gst-rtsp-server.json",
        "build-aux/flatpak/files/libprotobuf-c/libprotobuf-c.json",
        "build-aux/flatpak/files/NetworkManager/NetworkManager.json",
        "build-aux/flatpak/files/libportal/libportal.json",
        {
            "name": "desktopcast",
            "buildsystem": "meson",
            "build-options": {
                "env": {
                    "PKG_CONFIG_PATH": "/app/lib64/pkgconfig:/app/lib/pkgconfig:/usr/lib/x86_64-linux-gnu/pkgconfig:/usr/share/pkgconfig"
                }
            },
            "config-opts": [
                "-Dfirewalld_zone=false",
                "-Dbuild_daemon=false"
            ],
            "sources": [
                {
                    "type": "dir",
                    "path": "."
                }
            ]
        }
    ]
}
